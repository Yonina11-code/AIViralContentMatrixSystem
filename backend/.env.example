# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aiviral

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# LLM (DeepSeek compatible with OpenAI SDK)
LLM_API_KEY=your_deepseek_api_key_here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# Google Custom Search API
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CSE_ID=your_custom_search_engine_id_here

# WeChat Official Account
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# App
APP_NAME=AIViralContentMatrixSystem
DEBUG=true

# SSO (FlowTest)
# SSO_DOMAIN=your_flowtest_domain
# SSO_LOGIN_PATH=/login
# SSO_CALLBACK_PATH=/api/sso/callback
# SSO_TOKEN_EXPIRE_MINUTES=10
# SSO_REQUIRE_HTTPS=false
# SSO_VERIFY_CALLBACK=true
# SSO_JWT_SECRET=change-this-to-a-secure-key
